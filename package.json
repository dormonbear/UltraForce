{
  "name": "ultraforce-plasmo",
  "version": "0.3.1",
  "type": "module",
  "displayName": "UltraForce for Salesforce",
  "description": "Modern Salesforce metadata search and management tool",
  "author": "UltraForce Team",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "build:e2e": "PLASMO_PUBLIC_E2E=true plasmo build",
    "package": "plasmo package",
    "build:package": "pnpm build && pnpm package",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:e2e": "pnpm build:e2e && playwright test",
    "type-check": "tsc --noEmit",
    "release:patch": "node scripts/bump-version.mjs patch",
    "release:minor": "node scripts/bump-version.mjs minor",
    "release:major": "node scripts/bump-version.mjs major",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "eslint --fix"
  },
  "keywords": [
    "salesforce",
    "chrome-extension",
    "metadata",
    "react"
  ],
  "license": "MIT",
  "manifest": {
    "commands": {
      "toggle-search": {
        "suggested_key": {
          "default": "Ctrl+B",
          "mac": "Command+B"
        },
        "description": "Toggle UltraForce Search"
      }
    },
    "permissions": [
      "storage",
      "activeTab",
      "tabs",
      "cookies"
    ],
    "host_permissions": [
      "https://*.salesforce.com/*",
      "https://*.salesforce-setup.com/*",
      "https://*.visual.force.com/*",
      "https://*.visualforce.com/*",
      "https://*.lightning.force.com/*",
      "https://*.my.salesforce.com/*",
      "https://*.force.com/*",
      "https://*.sfcrmapps.cn/*",
      "https://*.sfcrmproducts.cn/*",
      "https://*.setup.sfcrmproducts.cn/*",
      "https://*.setup.sfcrmapps.cn/*",
      "https://login.salesforce.com/*",
      "https://test.salesforce.com/*"
    ]
  },
  "dependencies": {
    "minisearch": "^7.2.0",
    "plasmo": "^0.90.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^17.0.7",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18",
    "vitest-chrome": "0.1.0"
  }
}
