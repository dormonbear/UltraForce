{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmitOnError": false,
    "declaration": false,
    "declarationMap": false,
    "noUncheckedIndexedAccess": false,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "~*": [
        "./*"
      ],
      "~types": [
        "./types"
      ],
      "~lib/*": [
        "./lib/*"
      ],
      "~components/*": [
        "./components/*"
      ],
      "~contents/*": [
        "./contents/*"
      ]
    }
  },
  "include": [
    ".plasmo/index.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist"
  ]
}
